# Base de datos.
# Local (demo offline): SQLite en un archivo.
DATABASE_URL="file:./dev.db"
# Producción (Vercel + Neon): pega aquí la connection string de Neon (pooled).
# El proveedor se detecta automáticamente por el prefijo de la URL.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Secreto para firmar las sesiones del panel. Cámbialo en producción.
SESSION_SECRET="ffr-demo-secret-change-me"

# (Opcional) Valuación con IA real.
# Si defines una clave, la herramienta de valuación usa Claude (claude-opus-4-8)
# para refinar la estimación y añadir una justificación. Si NO la defines,
# la valuación usa el modelo de comparables (sin coste, funciona offline).
# ANTHROPIC_API_KEY="sk-ant-..."

# Clave para cifrar credenciales de integraciones (AES-256-GCM). Genera una con:
#   openssl rand -hex 32
APP_ENCRYPTION_KEY="pon-aqui-64-hex-chars"

# Token del store Blob (Vercel lo crea automáticamente en el proyecto).
# En local, pégalo desde Vercel > Storage > tu Blob > .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
