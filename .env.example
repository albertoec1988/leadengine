# Base de datos (SQLite local para la demo)
DATABASE_URL="file:./dev.db"

# Secreto para firmar las sesiones del panel. Cámbialo en producción.
SESSION_SECRET="ffr-demo-secret-change-me"

# (Opcional) Valuación con IA real.
# Si defines una clave, la herramienta de valuación usa Claude (claude-opus-4-8)
# para refinar la estimación y añadir una justificación. Si NO la defines,
# la valuación usa el modelo de comparables (sin coste, funciona offline).
# ANTHROPIC_API_KEY="sk-ant-..."
